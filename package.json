{
  "name": "web-landing",
  "version": "1.0.6",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node src/main/build/build.js",
    "dev:serve": "cross-env PORT=8018 node public/server.js",
    "dev": "npm run build && npm test && npm run dev:serve",
    "audit": "npm audit --audit-level moderate",
    "audit:prod": "npm audit --production --audit-level high",
    "lint": "eslint . --ext .js,.jsx",
    "test": "cross-env NODE_ENV=testrunner node src/test/test-runner.js",
    "clean": "node src/main/build/clean.js"
  },
  "dependencies": {
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.9",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "cpy-cli": "^4.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.39.4",
    "fs-extra": "^11.3.4",
    "gh-pages": "^6.3.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2"
  }
}
