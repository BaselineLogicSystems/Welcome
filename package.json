{
  "name": "web-landing",
  "version": "1.0.6",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node src/main/build/build.js && npm test",
    "dev:serve": "cross-env PORT=8018 ENABLE_DB_LOCAL=false node public/server.js",
    "dev": "npm run build && npm run dev:serve",
    "docker:build": "docker build -t web-landing .",
    "docker:run": "docker run -it --rm -p 8018:8018 web-landing",
    "audit": "npm audit --audit-level moderate",
    "audit:prod": "npm audit --production --audit-level high",
    "gh-pages": "git push -f origin `git subtree split --prefix public main`:gh-pages",
    "publish": "npm run build && npm run audit:prod && npm run gh-pages",
    "lint": "eslint . --ext .js,.jsx",
    "test-old": "cross-env NODE_ENV=testrunner node src/test/js/server.test.js && cross-env NODE_ENV=testrunner node src/test/js/calendarApi.test.js && cross-env NODE_ENV=testrunner node src/test/js/emailApi.test.js && cross-env NODE_ENV=testrunner node src/test/js/newsletterApi.test.js",
    "test": "cross-env NODE_ENV=testrunner node src/test/test-runner.js",
    "clean": "node src/main/build/clean.js"
  },
  "dependencies": {
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "mongoose": "^9.6.3",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.9",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "redis": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "cpy-cli": "^4.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.39.4",
    "fs-extra": "^11.3.4",
    "gh-pages": "^6.3.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2"
  }
}
