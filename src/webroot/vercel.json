
{
  "version": 2,
  "functions": {
    "api/server.js": {
      "includeFiles": "public/pages/**"
    },
    "api/routes/web.routes.js": {
      "includeFiles": "public/pages/**"
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/api/server.js"
    }
  ]
}

