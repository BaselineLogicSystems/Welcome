
{
  "version": 2,
  "builds": [{
    "src": "api/server.js", "use": "@vercel/node"
  }],
  "functions": {
    "api/server.js": {
      "includeFiles": "public/pages/*"
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/api/server.js"
    }
  ]
}