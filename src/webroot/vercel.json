
{
  "version": 2,
  "functions": {
    "api/server.js": {
      "includeFiles": "public/pages/**"
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/",
      "dest": "/pages/survey.html"
    },
    {
      "src": "/(.*).html",
      "dest": "/pages/$1.html"
    },
    {
      "src": "/favicon.ico",
      "dest": "/images/favicon.png"
    },
    {
      "src": "/(.*)",
      "dest": "/api/server.js"
    }
  ]
}

