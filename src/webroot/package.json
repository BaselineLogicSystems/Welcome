{
  "name": "web-landing",
  "version": "1.0.6",
  "private": true,
  "type": "module",
  "scripts": {
    "audit": "npm audit --audit-level moderate",
    "audit:prod": "npm audit --production --audit-level high",
    "build": "npm install",
    "dev": "cross-env PORT=8018 NODE_ENV=development node api/server.js",
    "lint": "eslint . --ext .js,.jsx",
    "test": "cross-env NODE_ENV=testrunner node ../test/test-runner.js",
    "start": "cross-env NODE_ENV=production node api/server.js"
  },
  "dependencies": {
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "mongoose": "^9.0.0",
    "nodemailer": "^9.0.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "cpy-cli": "^4.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.39.4",
    "fs-extra": "^11.3.4",
    "supertest": "^7.2.2"
  }
}
